# STMNA Desk — Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit your .env file to git.

# ── Paths ────────────────────────────────────────────────────────────────────

# Host path to your LLM/whisper model files
MODELS_DIR=/home/stmna/models

# Host path to persistent data (n8n, postgres, qdrant, etc.)
DATA_DIR=/home/stmna/data

# Host path to your Obsidian vault (mounted read-only into n8n)
VAULT_DIR=/data/second-brain

# ── Networking ────────────────────────────────────────────────────────────────

# Shared Podman network name (all stacks join this)
STMNA_NETWORK=stmna-net

# ── n8n ──────────────────────────────────────────────────────────────────────

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# n8n webhook base URL (public URL for incoming webhooks)
N8N_WEBHOOK_URL=https://n8.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_USER=voice
POSTGRES_PASSWORD=
POSTGRES_DB=stmna_signal

# ── llama-swap ────────────────────────────────────────────────────────────────

# Port for the llama-swap proxy
LLAMA_SWAP_PORT=8081

# ── whisper.cpp ───────────────────────────────────────────────────────────────

WHISPER_PORT=8083

# ── Caddy / Remote Access ─────────────────────────────────────────────────────

# Bearer token for public-facing endpoints (voice, n8n webhooks)
# Generate with: openssl rand -hex 32
CADDY_BEARER_TOKEN=

# Your public domain (used by Caddy for TLS)
PUBLIC_DOMAIN=yourdomain.com
